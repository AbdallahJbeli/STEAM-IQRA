// This configures TypeScript compilation.

// - **src**: Source code location.
// - **dist**: Compiled output location.
// - **commonjs**: Module system for Node.js.
// - **strict**: Enforces strict type checking.

{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  }
}